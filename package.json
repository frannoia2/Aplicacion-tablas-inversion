  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/frannoia2/Aplicacion-tablas-inversion/issues"
  },
  "homepage": "https://github.com/frannoia2/Aplicacion-tablas-inversion#readme",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4"
  },
  "build": {
    "appId": "com.frannoia.aplicacion-tablas-inversion",
    "productName": "AplicacionTablasInversion",
